# 生产 .env 模板。复制成 .env 后填真值，权限 chmod 600。

# === 必改 ===
DATABASE_URL=mysql+pymysql://interview:STRONG_PWD_HERE@127.0.0.1:3306/interview_assistant

# 生成方式：openssl rand -hex 32
JWT_SECRET=REPLACE_ME_64_HEX_CHARS

# 上线域名（CSV，无尾斜杠）
CORS_ORIGINS=https://app.example.com,https://admin.example.com

# 部署环境标记
ENV=prod

# === 可选 ===
JWT_EXPIRE_DAYS=7
TRONGRID_API_KEY=
