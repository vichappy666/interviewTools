# 本机 dev 用模板。生产部署请参考 deploy/.env.prod.example 和 docs/deployment-vps.md。
# JWT_SECRET 生产必改：openssl rand -hex 32
# CORS_ORIGINS 上线改成线上域名（https://app.example.com,https://admin.example.com）
# DATABASE_URL 用专用 MySQL 账号，不要用 root

DATABASE_URL=mysql+pymysql://root:password@localhost:3306/interview_assistant
JWT_SECRET=please-run-openssl-rand-hex-32-and-paste-here
JWT_EXPIRE_DAYS=7
TRONGRID_API_KEY=
ENV=local
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
